# ベーシック認証（両方設定すると有効化。Firebase Auth とは独立してミドルウェア層で動作）
BASIC_USER=admin
BASIC_PASS=your_password

# OpenAI（サーバー側・無料枠用）
OPENAI_API_KEY=sk-...

# Gemini（サーバー側・無料枠用）
GEMINI_API_KEY=AI...

# ===== Firebase Admin SDK（サーバー側 / Firestore + IDトークン検証）=====
# 設定するとコーパスがFirestoreに永続化される。セットアップ手順 → docs/firebase-setup.md
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ===== Firebase Web SDK（クライアント側 / Auth 用）=====
# Firebase Console → プロジェクト設定 → 全般 → マイアプリ（ウェブ）から取得
# 設定するとサインイン UI が有効化される。未設定時はローカル専用モード（localStorage のみ）
NEXT_PUBLIC_FIREBASE_API_KEY=AIza...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_APP_ID=1:1234567890:web:abcdef1234567890
